# .clangd
CompileFlags:
  # 解决PlatformIO项目与clangd的兼容问题
  Remove:
    - -mlongcalls
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -fno-rtti
    - -fexceptions
    - -fno-exceptions
Diagnostics:
  # 开启严格模式
  ClangTidy:
    Add: [
      # bugprone-*：检测容易出 bug 的写法，例如未初始化变量、危险的指针操作等。
      "bugprone-*",
      # performance-*：检测低效代码，例如不必要的拷贝、低效循环等。
      "performance-*",
      # readability-*：提高代码可读性，例如变量命名、冗余表达式等。
      "readability-*",
      # modernize-*：建议使用现代 C++ 写法，例如使用 nullptr、使用 override 等。
      "modernize-*",
      # cppcoreguidelines-*：C++ 核心指南，提供更严格的代码规范检查。
      "cppcoreguidelines-*",
      # misc-*：初学者常犯的错误，例如不安全的宏、错误的比较等。
      "misc-*",
      # hicpp-*：更严格的 C++ 规则（High Integrity C++），适合初学者养成好习惯。
      "hicpp-*",

      # Clang 静态分析器：检测隐藏 bug，如空指针、未初始化变量、内存泄漏、逻辑路径错误等
      "clang-analyzer-*",
      # 跨平台检查：避免 PC 上正常但 MCU 上出问题的代码，如类型大小、字节序、对齐方式等
      "portability-*",
      # 并发检查：检测 FreeRTOS/多线程中的数据竞争、锁误用、原子操作问题等
      "concurrency-*",
      # 安全检查：发现潜在漏洞，如缓冲区溢出、不安全字符串操作、未检查返回值等
      "security-*",
      # Google Fuchsia 风格规则：更严格的现代 C++ 风格建议
      "fuchsia-*",
    ]
